{
  "name": "lexthority",
  "version": "0.1.0",
  "private": true,
  "description": "Authority seam for agent work: envelopes, effect decisions, and receipts.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean && rm -rf packages/*/dist",
