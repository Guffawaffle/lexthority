    "check": "npm run build && npm test",
    "cli": "node packages/lex-thority-cli/dist/index.js"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
